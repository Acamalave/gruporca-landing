rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Correos del equipo autorizados a ver los leads en el panel /admin.
    // Para agregar a alguien, añade su correo a esta lista.
    function isAdmin() {
      return request.auth != null
             && request.auth.token.email in [
                  "malave.acacio@gmail.com"
                ];
    }

    // Cotizaciones del formulario de contacto: el publico solo puede crear.
    // El equipo (admin) puede leer desde el panel.
    match /leads/{leadId} {
      allow create: if request.resource.data.nombre is string
                    && request.resource.data.nombre.size() > 0
                    && request.resource.data.whatsapp is string
                    && request.resource.data.whatsapp.size() > 0;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Cotizaciones de repuestos: el publico solo puede crear.
    // El equipo (admin) puede leer desde el panel.
    match /partsQuotes/{quoteId} {
      allow create: if request.resource.data.nombre is string
                    && request.resource.data.nombre.size() > 0
                    && request.resource.data.whatsapp is string
                    && request.resource.data.whatsapp.size() > 0;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Perfil de visitante: cada navegador (login anonimo) gestiona SU propio
    // documento (id = uid anonimo). El equipo (admin) puede leer todos.
    match /visitors/{visitorId} {
      allow create, update: if request.auth != null && request.auth.uid == visitorId;
      allow read: if isAdmin();
      allow delete: if false;
    }

    // Eventos de navegacion: el visitante solo crea eventos a su nombre (uid).
    // El equipo (admin) los lee.
    match /events/{eventId} {
      allow create: if request.auth != null
                    && request.resource.data.visitorId == request.auth.uid;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Busquedas / interes (buscador de equipos y chatbot): el publico crea,
    // el equipo (admin) lee. No guardan datos personales.
    match /searches/{searchId} {
      allow create: if request.resource.data.type is string
                    && request.resource.data.type.size() > 0;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Ordenes de servicio: el publico puede consultar una orden por su ID,
    // pero no listar todas ni escribir.
    match /serviceOrders/{orderId} {
      allow get: if true;
      allow list, write: if false;
    }

    // Todo lo demas queda bloqueado.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
